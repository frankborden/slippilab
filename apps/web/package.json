    "@slippilab/server": "workspace:*",
    "@types/three": "^0.160.0",
    "clsx": "^2.1.0",
    "fflate": "^0.8.1",
    "react": "^18.2.0",
    "react-aria-components": "^1.0.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "three": "^0.160.0",
    "three-stdlib": "^2.29.4",
    "zustand": "^4.5.1"
